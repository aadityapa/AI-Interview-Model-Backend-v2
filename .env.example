# --- OpenAI keys (place in .env at project root: D:\AI-Interview-Model-\.env) ---
# OPENAI_API_KEY is the master fallback for all AI features.
# Optional per-purpose keys (if unset, each falls back to OPENAI_API_KEY):
# OPENAI_API_KEY=your_openai_api_key   # master fallback (ATS, OCR, etc.)
# Either naming style works for the four purpose keys:
# OPENAI_TTS_API_KEY=sk-...            # or OPENAI_API_KEY_TTS
# OPENAI_QUESTION_API_KEY=sk-...       # or OPENAI_API_KEY_QUESTIONS
# OPENAI_EVAL_API_KEY=sk-...           # or OPENAI_API_KEY_EVALUATION
# OPENAI_TRANSCRIBE_API_KEY=sk-...     # or OPENAI_API_KEY_TRANSCRIBE
# OPENAI_BASE_URL=https://api.openai.com/v1   # optional proxy / Azure-compatible endpoint

# Frontend static files (split-repo layout).
# Leave unset to auto-detect sibling AI-Interview-Model-F-V2/frontend, or monolith frontend/ in this repo.
# FRONTEND_DIR=D:\AI-Interview-Model-F-V2\frontend

# CORS
# If you leave this unset/blank, the server will auto-allow localhost + any LAN IPv4 origin
# (so you don't need to edit IPs each time you run on a new machine/network).
# If you set it, it becomes strict and you must list every origin you will use.
#
# Example strict value:
# CORS_ALLOW_ORIGINS=http://127.0.0.1:2020,http://localhost:2020,https://192.168.1.41:2020
CORS_ALLOW_ORIGINS=

# Base URL in emailed invite links.
# - Best: open the HR app using your machine's LAN URL (e.g. https://192.168.1.58:2020). The server
#   then builds invite links from that same Host (works when your IP changes on the network).
# - Leave unset or set "auto": substitute LAN IPv4 when the browser uses localhost.
# - Avoid hard-coding an old IP here unless you use a stable hostname.
PUBLIC_BASE_URL=auto

# Invite interviews load skills/questions from saved ATS job config (data/job_configs.json).
# INTERVIEW_JOB_ID=
# INTERVIEW_OPENAI_MODEL=gpt-4o-mini
# INTERVIEW_SAFE_MODE=false
# INTERVIEW_FOLLOWUP_MODE=false
# INTERVIEW_MODE_AWARE_GENERATION=true
# INTERVIEW_DIFFICULTY=medium
# INTERVIEW_NUM_QUESTIONS=7
# Default ON. Set to "false" to disable the non-evaluated "Please introduce
# yourself" warmup turn that ships with every interview (Issue 2, May 2026).
# The warmup is not scored, not appended to the learning ledger, and is
# stripped from HR report records.
# INTERVIEW_WARMUP_QUESTION_ENABLED=true
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Change this in production. Avoid default values.
REPORT_CODE=change_this_secret_code
AUTH_SECRET=change_this_jwt_secret
# Block open HR self-registration unless explicitly enabled.
ALLOW_PUBLIC_HR_REGISTRATION=false
AUTH_TOKEN_TTL_MIN=480
# Max POST /auth/login and /auth/register attempts per client IP per rolling 60s window (default 30).
# AUTH_LOGIN_RATE_LIMIT=30
# SECURITY_HEADERS_ENABLED=true
# HSTS_ENABLED=false
# INTEGRITY_LOGS_CACHE_TTL_S=20
# OPENAI_RETRY_MAX=2
# OPENAI_RESPONSE_CACHE_ENABLED=false
# OPENAI_RESPONSE_CACHE_TTL_S=86400
# RATE_LIMIT_ENABLED=false
# Supabase SDK (Project Settings → API)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_KEY=your-anon-or-service-role-key

# Database — AWS RDS, Supabase, or any PostgreSQL
# AUTH_DB_URL=postgresql://postgres:[PASSWORD]@database-1.xxxxx.ap-south-1.rds.amazonaws.com:5432/karnex_db
# DATABASE_URL is accepted as an alias for AUTH_DB_URL.
# sslmode=require is added automatically for cloud hosts (RDS, Supabase, Render).
# AUTH_DB_URL=

# Optional runtime tuning for container/server.
PORT=2020
# In-memory sessions — keep at 1 until REDIS_URL backs session state.
UVICORN_WORKERS=1

# SMTP disabled by default. Set SMTP_ENABLED=true and credentials to send invite emails.
SMTP_ENABLED=false
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=you@yourdomain.com
# SMTP_PASSWORD=your_password_or_app_password
# SMTP_FROM=you@yourdomain.com
# SMTP_USE_TLS=true
